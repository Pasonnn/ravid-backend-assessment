{
  "id": null,
  "uid": "ravid-observability",
  "title": "R.A.V.I.D. Observability",
  "tags": [
    "ravid",
    "observability"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(service)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Live Logs by Service",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 13,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=~\"$service\"} | json",
          "queryType": "range"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Logs (Last 30m)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service=~\"$service\"} | json | level=\"ERROR\" [30m]))",
          "queryType": "instant"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Top 5 Slowest CSV Operations (Last 30m)",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(5, max_over_time({service=\"celery\"} | json | unwrap duration_ms [30m]))",
          "queryType": "instant",
          "legendFormat": "{{operation}}"
        }
      ],
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      }
    }
  ]
}
